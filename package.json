{
  "name": "searxng-deepdive",
  "version": "0.2.0",
  "description": "MCP server for SearXNG with engine/category targeting, multi-page fanout, and dynamically-generated tool descriptions tailored to the instance's actual enabled engine pool.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "searxng-deepdive": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "probe": "tsx scripts/probe.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "searxng",
    "search",
    "metasearch",
    "llm",
    "agent",
    "tools"
  ],
  "license": "MIT",
  "author": {
    "name": "Burak Aydın"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/burakaydinofficial/searxng-deepdive.git"
  },
  "bugs": {
    "url": "https://github.com/burakaydinofficial/searxng-deepdive/issues"
  },
  "homepage": "https://github.com/burakaydinofficial/searxng-deepdive#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "node-html-markdown": "^2.0.0",
    "undici": "^6.20.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
